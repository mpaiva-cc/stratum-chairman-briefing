source "https://rubygems.org"

# Local-development Gemfile. GitHub Pages builds the site server-side using
# its own pinned versions (https://pages.github.com/versions/) and ignores
# this file, so we use plain Jekyll here for fast local previews.
gem "jekyll", "~> 4.3"

group :jekyll_plugins do
  gem "jekyll-sitemap"
  gem "jekyll-feed"
end

gem "webrick", "~> 1.8"
